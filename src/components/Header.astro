---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const navItems = [
  { label: '首页', path: '/', label_en: 'Home' },
  { label: '作品', path: '/works', label_en: 'Works' },
  { label: '视频', path: '/video', label_en: 'Video' },
  { label: '关于', path: '/about', label_en: 'About' },
  { label: '联系', path: '/contact', label_en: 'Contact' },
];
---

<header class="header">
  <div class="header-shell">
    <div class="header-content">
      <div class="logo">
        <a href="/">
          <img src="/avatar.png" alt="樊赛娅" class="logo-avatar" />
          <div class="logo-text-wrapper">
            <span class="logo-text">樊赛娅</span>
            <span class="logo-subtitle">Environment Portfolio</span>
          </div>
        </a>
      </div>

      <nav class="nav" aria-label="主导航">
        <ul class="nav-list">
          {navItems.map((item) => (
            <li class="nav-item">
              <a href={item.path} class={`nav-link ${currentPath === item.path ? 'active' : ''}`} title={item.label_en}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    padding: 0;
    pointer-events: none;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
  }

  .header-shell {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(2rem, 5vw, 4rem);
  }

  .header-content {
    pointer-events: auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--spacing-xl);
    padding: 1rem 0;
  }

  .logo a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .logo a:hover {
    opacity: 0.8;
  }

  .logo-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(212, 175, 55, 0.3);
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.2);
  }

  .logo-text-wrapper {
    display: flex;
    flex-direction: column;
  }

  .logo-text {
    font-family: var(--font-family-display);
    font-size: 1.25rem;
    font-weight: var(--font-weight-bold);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
  }

  .logo-subtitle {
    font-size: 0.9375rem;
    color: rgba(212, 175, 55, 0.7);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.15rem;
  }

  .nav-list {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style: none;
    gap: 2rem;
  }

  .nav-link {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    position: relative;
    padding-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    transform: scaleX(0);
    transform-origin: center;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    transition: transform var(--transition-normal);
  }

  .nav-link:hover,
  .nav-link.active {
    color: #d4af37;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
    padding: 0.75rem 1.5rem;
    border-radius: 2rem;
    color: #000;
    background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: all var(--transition-fast);
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
  }

  .header-cta:hover {
    background: linear-gradient(135deg, #f4d03f 0%, #d4af37 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(212, 175, 55, 0.4);
  }

  @media (max-width: 900px) {
    .header-shell { padding: 0 var(--spacing-lg); }
    .header-content {
      grid-template-columns: 1fr;
      padding: 1rem 0;
      gap: 1rem;
    }
    .nav-list { justify-content: flex-start; gap: 1rem 1.5rem; }
    .header-cta { justify-self: start; }
  }
</style>
