---
import content from '@/content.json';
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-section">
      <h3>联系方式</h3>
      <ul class="contact-list">
        <li>
          <a href="mailto:fansaiya@163.com">
            <span class="label">邮箱</span>
            <span class="value">fansaiya@163.com</span>
          </a>
        </li>
        <li>
          <span class="label">微信</span>
          <span class="value">13357702487</span>
        </li>
      </ul>
    </div>

    <div class="footer-section">
      <h3>快速链接</h3>
      <ul class="links-list">
        <li><a href="/">首页</a></li>
        <li><a href="/works">作品集</a></li>
        <li><a href="/video">视频</a></li>
        <li><a href="/about">关于我</a></li>
        <li><a href="/contact">联系</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h3>简历下载</h3>
      <ul class="links-list">
        <li>
          <a href="/downloads/resume.pdf" target="_blank" rel="noopener">
            个人简历 PDF
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="copyright">{content.footer.copyright}</p>
    <p class="credit">设计与开发：樊赛娅</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #000;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: 0;
    padding: clamp(4rem, 8vw, 6rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    max-width: 1440px;
    margin: 0 auto clamp(3rem, 6vw, 5rem);
    padding: 0 clamp(2rem, 5vw, 4rem);
    gap: clamp(2rem, 4vw, 3rem);
  }

  .footer-section h3 {
    font-family: var(--font-family-display);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: #fff;
    margin-bottom: var(--spacing-lg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-list,
  .links-list {
    list-style: none;
  }

  .contact-list li {
    margin-bottom: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .contact-list a {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    transition: opacity var(--transition-fast);
  }

  .contact-list a:hover {
    opacity: 0.7;
  }

  .label {
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: var(--font-weight-bold);
  }

  .value {
    color: #fff;
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-base);
  }

  .links-list li {
    margin-bottom: var(--spacing-md);
  }

  .links-list a {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
    font-weight: var(--font-weight-medium);
  }

  .links-list a:hover {
    color: #fff;
  }

  .footer-bottom {
    text-align: center;
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 1440px;
    margin: 0 auto;
    padding-left: clamp(2rem, 5vw, 4rem);
    padding-right: clamp(2rem, 5vw, 4rem);
  }

  .copyright,
  .credit {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  .credit {
    margin-top: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      padding: 0 var(--spacing-lg);
    }

    .footer-bottom {
      padding: var(--spacing-2xl) var(--spacing-lg) var(--spacing-lg);
    }
  }
</style>
