---
import Layout from '@/layouts/Layout.astro';
import content from '@/content.json';
import '@/styles/index.css';

const featuredWorks = content.works.slice(0, 3);
---

<Layout title={content.site.title} description={content.site.description} currentPath="/">
  <section class="hero">
    <div class="hero-background"></div>
    <div class="hero-content">
      <h1 class="hero-title">{content.hero.title}</h1>
      <p class="hero-subtitle">{content.hero.subtitle}</p>
      <div class="hero-actions">
        <a href={content.hero.cta_link} class="cta-button">{content.hero.cta}</a>
      </div>
    </div>
  </section>

  <section class="featured-works">
    <div class="works-grid">
      {featuredWorks.map((work) => (
        <article class="work-card">
          <a href={`/project/${work.id}`}>
            <div class="work-image">
              <img src={work.coverImage} alt={work.title} loading="lazy" />
            </div>
            <div class="work-overlay">
              <div class="work-info">
                <span class="work-category">{work.category}</span>
                <h3>{work.title}</h3>
                <p>{work.shortDescription}</p>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>查看完整作品集</h2>
      <p>探索更多 UE5 游戏环境设计与地编项目</p>
      <div class="hero-actions">
        <a href="/works" class="cta-button">浏览全部作品</a>
      </div>
    </div>
  </section>
</Layout>
