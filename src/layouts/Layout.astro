---
import '@/styles/design-system.css';
import '@/styles/globals.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = '樊赛娅 - 游戏地编作品集',
  description = 'UE5 游戏环境美术设计与地编作品集',
  currentPath = '/',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>

    <style is:global>
      html {
        color-scheme: dark;
      }
    </style>
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main class="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      // 鼠标位置跟踪
      document.addEventListener('mousemove', (e) => {
        document.documentElement.style.setProperty('--mouse-x', e.clientX + 'px');
        document.documentElement.style.setProperty('--mouse-y', e.clientY + 'px');
      });
    </script>
  </body>
</html>

<style>
  :global(body) {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    cursor: none;
  }

  :global(body::after) {
    content: '';
    position: fixed;
    pointer-events: none;
    z-index: 10000;
    width: 20px;
    height: 20px;
    background: radial-gradient(circle, #ffffff 0%, #d4af37 70%, transparent 100%);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    left: var(--mouse-x, -100px);
    top: var(--mouse-y, -100px);
    transition: left 0.1s ease-out, top 0.1s ease-out;
    box-shadow:
      0 0 20px rgba(255, 255, 255, 0.8),
      0 0 40px rgba(212, 175, 55, 0.6),
      0 0 60px rgba(212, 175, 55, 0.4);
    animation: cursorPulse 2s ease-in-out infinite;
  }

  :global(body::before) {
    content: '';
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 40px;
    height: 40px;
    border: 2px solid rgba(212, 175, 55, 0.5);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    left: var(--mouse-x, -100px);
    top: var(--mouse-y, -100px);
    transition: left 0.15s ease-out, top 0.15s ease-out, width 0.2s, height 0.2s;
  }

  @keyframes :global(cursorPulse) {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.2);
      opacity: 0.8;
    }
  }

  .main-content {
    flex: 1;
  }
</style>
